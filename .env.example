# CampusCore — environment variable template.
# Copy to `.env.local` (Next.js) and set the real values via the Convex
# dashboard / Vercel project settings. NEVER commit real values (AGENTS.md).
# Each var lists where to obtain it. See WAITING_ON_HUMAN.md for the full list.

# --- Convex ---------------------------------------------------------------
# Deployment URL printed by `npx convex dev`, and the deploy key from the
# Convex dashboard (Project Settings → Deploy keys).
NEXT_PUBLIC_CONVEX_URL=
CONVEX_DEPLOY_KEY=

# --- Clerk (auth, restricted to @smu.edu.sg at the DASHBOARD level) -------
# From the Clerk dashboard → API Keys. The publishable key is client-safe;
# the secret key is server-only. Domain restriction is set in Clerk, not here.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# JWKS endpoint used by the Convex backend to verify RS256 session JWTs.
# Format: https://<your-clerk-domain>/.well-known/jwks.json
CLERK_JWKS_URL=
# Clerk JWT issuer domain (e.g. https://your-app.clerk.accounts.dev). Set this
# as a CONVEX env var (`npx convex env set CLERK_JWT_ISSUER_DOMAIN ...`) — it is
# read by convex/auth.config.ts, not by Next.js.
CLERK_JWT_ISSUER_DOMAIN=

# --- Telegram Bot ---------------------------------------------------------
# Token from @BotFather. Store in Convex env vars (not client-exposed).
# The webhook URL is registered via setWebhook to the Convex HTTP endpoint.
TELEGRAM_BOT_TOKEN=
# Shared secret echoed in Telegram's X-Telegram-Bot-Api-Secret-Token header
# (set when calling setWebhook) so the handler can reject spoofed updates.
TELEGRAM_WEBHOOK_SECRET=

# --- LLM triage (structured headline/location extraction) -----------------
# Groq API key (console.groq.com) for the Llama-3 structured-output call,
# OR point at a local Ollama instance. Severity output is ignored on a
# lexicon match (tech_design §3).
GROQ_API_KEY=
LLM_BASE_URL=

# --- Resend (emergency escalation email only, free tier 3,000/mo) ---------
# API key from resend.com → API Keys. CSOC intake inbox is the recipient.
RESEND_API_KEY=
CSOC_INTAKE_EMAIL=

# --- Cloudflare (CSAM hash-match zone — dashboard setup, see WAITING) -----
# Upload endpoint that is orange-clouded (DNS-proxied) through Cloudflare.
CLOUDFLARE_UPLOAD_ENDPOINT=
# Feature flag: keep "false" until the zone is genuinely orange-clouded and
# the CSAM tool is enabled. Code path is stubbed off when false (tech_design §4).
CSAM_SCAN_ENABLED=false

# --- Multi-school template (one deployment per school) --------------------
# Which school THIS deployment serves. Must match a `code` in
# config/schoolRegistry.ts (e.g. smu, nus, ntu, np, sp, tp, nyp, rp, ite).
# SET THIS IN BOTH the Next.js env AND the Convex env (separate runtimes).
CAMPUSCORE_SCHOOL_CODE=smu
# Authorized admins: comma/space-separated staff-domain emails. An admin must
# (1) verify a staff-domain email via Clerk AND (2) appear here. Empty = no
# admins (fails closed). Domain match alone is never sufficient.
CAMPUSCORE_ADMIN_ALLOWLIST=

# --- App ------------------------------------------------------------------
# Public base URL of the deployed Next.js app (Vercel).
NEXT_PUBLIC_APP_URL=
